  m_Script: {fileID: 11500000, guid: f51a2c182a3a1804b80dd3b15fc3579d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::InteractibleObject
  ObjAction: Use TV
  requiredItem: {fileID: 11400000, guid: 0680f55c080d96d46b3ad7b70c264d7b, type: 2}
  _refusalTextList:
  - Hmm a TV...I would love to have one in my room...
  - It seems that I can connect a camera to it.
  - I would love to watch some cartoons
  - Oh well...
  _acceptanceTextList:
  - '*Plugs in the Cam Corder*'
  - Oh, what is...Is this the school?!
  - I remember now! they shoved me into the locker
  - This is how I got here!
  _refusalAudioClip: {fileID: 8300000, guid: 45e884d65bb420a4c8071249ceb0f3f5, type: 3}
  _acceptanceAudioClip: {fileID: 8300000, guid: 54932036d6b986a45be581b8f963cceb, type: 3}
  _refusalAnimTriggerName: NoTape
